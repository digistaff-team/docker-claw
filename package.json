{
  "name": "bash-executor-v3",
  "version": "3.0.0",
  "description": "AI Bash Executor with PostgreSQL and Persistent Storage",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node tests/content.status.test.js && node tests/validators.extended.test.js && node tests/wordpress.publisher.test.js && node tests/blog.generator.test.js && node tests/blog.moderation.test.js",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.js",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.js --ui",
    "test:e2e:debug": "playwright test --config=tests/e2e/playwright.config.js --debug",
    "test:e2e:headed": "playwright test --config=tests/e2e/playwright.config.js --headed",
    "test:e2e:smoke": "playwright test --config=tests/e2e/playwright.config.js tests/e2e/specs/0-critical-path.spec.js",
    "test:e2e:ci": "cross-env E2E_MODE=real playwright test --config=tests/e2e/playwright.config.js --reporter=html"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "imap-simple": "^1.6.3",
    "imapflow": "^1.2.18",
    "mailparser": "^3.7.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.20.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.3",
    "session-file-store": "^1.5.0",
    "sharp": "^0.34.5",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.1"
  }
}
