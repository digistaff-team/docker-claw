# Docker-Claw Configuration Example
# Copy this file to .env and fill in your values

# ===========================================
# Server
# ===========================================
PORT=3015

# ===========================================
# App URL (IMPORTANT for Telegram inline keyboard)
# ===========================================
# For production: use your public HTTPS domain
# APP_URL=https://your-domain.com

# For local development: use ngrok or similar tunnel
# 1. Install ngrok: https://ngrok.com/
# 2. Run: ngrok http 3015
# 3. Copy the HTTPS URL (e.g., https://abc123.ngrok-free.app)
# APP_URL=https://abc123.ngrok-free.app

# ===========================================
# Telegram Bot Tokens
# ===========================================
# Main auth bot token (@clientzavod_bot)
BOT_TOKEN=your_telegram_bot_token_here

# Auth bot token for @clientzavod_bot (used by server.js)
AUTH_BOT_TOKEN=your_auth_bot_token_here

# ===========================================
# Telegram Webhook (optional, for faster bot response)
# ===========================================
# If set, the bot will use webhook instead of long polling
# Webhook provides instant message delivery vs 1-3s delay with polling
# Format: https://your-domain.com/telegram/webhook/{bot_token}
# WEBHOOK_URL=https://your-domain.com/telegram/webhook/

# CW Bot Webhook URL (for content moderation bot)
# This is separate from WEBHOOK_URL to avoid routing conflicts
# Format: https://your-domain.com/cw-bot-webhook
# CW_BOT_WEBHOOK_URL=https://your-domain.com/cw-bot-webhook

# ===========================================
# API URL (for internal API calls)
# ===========================================
# For production
API_URL=https://clientzavod.ru

# For local development with ngrok
# API_URL=https://abc123.ngrok-free.app

# ===========================================
# PostgreSQL
# ===========================================
PG_HOST=172.17.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_postgres_password

# Admin host for DB operations (CREATE/DROP DATABASE)
PG_ADMIN_HOST=172.17.0.1

# Host passed to sandbox containers via PGHOST/DATABASE_URL
PG_SANDBOX_HOST=172.17.0.1

# ===========================================
# MySQL (Skills Database)
# ===========================================
# Host for MySQL skills database (use 'mysql' if running in Docker Compose)
MYSQL_SKILLS_HOST=localhost
MYSQL_SKILLS_PORT=3306
MYSQL_SKILLS_USER=ai_skills
MYSQL_SKILLS_PASSWORD=your_mysql_password_here
MYSQL_SKILLS_DATABASE=ai_skills_db

# ===========================================
# Docker
# ===========================================
# Sandbox image for user containers
DOCKER_IMAGE=mcr.microsoft.com/devcontainers/javascript-node:20-bookworm

# User container limits (sandbox-user-*)
# Оптимально для сервера с 2GB RAM и 10 пользователями:
CONTAINER_MEMORY=256m
CONTAINER_CPUS=0.5

# Container timeout in seconds (default: 24h)
CONTAINER_TIMEOUT=86400

# ===========================================
# Storage
# ===========================================
DATA_ROOT=/var/sandbox-data
BACKUP_ROOT=/var/sandbox-backups
BACKUP_INTERVAL_HOURS=168
SNAPSHOT_ROOT=/var/sandbox-snapshots
SNAPSHOT_MAX_DEPTH=10
SNAPSHOT_TTL_DAYS=7

# ===========================================
# AI & API Keys
# ===========================================
# Kie.ai API key for image generation
KIE_API_KEY=your_kie_api_key_here

# OpenAI API key (fallback or other AI features)
# OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# Content MVP / Scheduler
# ===========================================
# Scheduled time for content publishing (HH:MM format)
CONTENT_MVP_TIME=09:00

# Timezone for scheduler
CONTENT_MVP_TZ=Europe/Moscow

# Telegram channel ID for content publishing
CHANNEL_ID=-1002263032027

# Moderator user ID for content approval
CONTENT_MVP_MODERATOR_USER_ID=128247430

# Daily content limit
CONTENT_MVP_DAILY_LIMIT=1

# Max image generation attempts per post
CONTENT_MVP_MAX_IMAGE_ATTEMPTS=3

# Content type: 'text+image' | 'text+video'
CONTENT_MVP_CONTENT_TYPE=text+image

# ===========================================
# Video Generation
# ===========================================
# Video model: 'veo3' | 'veo3_fast'
VIDEO_MODEL=veo3_fast

# Video generation timeout in seconds
VIDEO_TIMEOUT_SEC=300

# Video status polling interval in seconds
VIDEO_POLL_INTERVAL_SEC=10

# Enable video fallback to image on failure
VIDEO_FALLBACK_ENABLED=true

# ===========================================
# Session Management
# ===========================================
# Max session idle time in milliseconds (default: 24h)
SESSION_MAX_IDLE_MS=86400000

# Session cleanup interval in milliseconds (default: 5min)
CLEANUP_INTERVAL_MS=300000

# ===========================================
# Project Cache
# ===========================================
PROJECT_CACHE_DIR=.project
PROJECT_CACHE_MAX_FILES=5000
PROJECT_CACHE_MAX_SUMMARY_SIZE=50000
PROJECT_CACHE_TTL_DAYS=30

# ===========================================
# VK Integration
# ===========================================
# VK API version
VK_API_VERSION=5.199

# Default VK group ID
# VK_DEFAULT_GROUP_ID=220517053

# Daily VK post limit
VK_DAILY_LIMIT=5

# Moderation timeout in hours (auto-reject after)
VK_MODERATION_TIMEOUT_HOURS=24

# ===========================================
# OK (Odnoklassniki) Integration
# ===========================================
# OK API Application ID
# OK_APP_ID=512003249088

# OK API Public Key (application_key)
# OK_PUBLIC_KEY=CBMEJGMGDILIFBABA

# OK API Secret Key
# OK_SECRET_KEY=14A51187183D92A46CC5CFF4

# OK API Access Token (long-lived)
# OK_ACCESS_TOKEN=your_ok_access_token_here

# OK API Session Secret (for request signing)
# OK_SESSION_SECRET=your_ok_session_secret_here

# OK Group ID for publishing
# OK_GROUP_ID=70000045843362

# Daily OK post limit
OK_DAILY_LIMIT=5

# Moderation timeout in hours (auto-reject after)
OK_MODERATION_TIMEOUT_HOURS=24

# ===========================================
# TikTok Integration
# ===========================================
# Daily TikTok post limit
TIKTOK_DAILY_LIMIT=3

# Moderation timeout in hours (auto-reject after)
TIKTOK_MODERATION_TIMEOUT_HOURS=24

# ===========================================
# Instagram Integration
# ===========================================
# Daily Instagram post limit
INSTAGRAM_DAILY_LIMIT=3

# Moderation timeout in hours (auto-reject after)
INSTAGRAM_MODERATION_TIMEOUT_HOURS=24

# ===========================================
# Facebook Integration
# ===========================================
# Daily Facebook post limit
FACEBOOK_DAILY_LIMIT=10

# Moderation timeout in hours (auto-reject after)
FACEBOOK_MODERATION_TIMEOUT_HOURS=24

# ===========================================
# Video Pipeline
# ===========================================
# Root folder for temporary video storage
VIDEO_TEMP_ROOT=/var/sandbox-data/.video-temp

# Cleanup scheduler interval in milliseconds (default: 5min)
VIDEO_CLEANUP_INTERVAL_MS=300000

# Minutes before deletion after all channels used the video
VIDEO_DELETION_DELAY_MIN=60

# KIE.ai video model (veo3.1 recommended for image-to-video)
VIDEO_MODEL=veo3.1

# Video aspect ratio (9:16 for vertical/Shorts/Reels/TikTok)
VIDEO_ASPECT_RATIO=9:16

# Comma-separated list of channels that share video content
# Video is deleted only when ALL listed channels have used it
# Remove channels from this list to make them optional
VIDEO_CHANNELS=youtube,tiktok,instagram

# ===========================================
# Central Moderation Bot (CW Bot)
# ===========================================
# Single bot for all users content moderation (verification code, approve/reject)
# Get token from @BotFather
CW_BOT_TOKEN=your_cw_bot_token_here

# Bot username (without @) - required for setup.html "Connect" button
CW_BOT_USERNAME=your_cw_bot_username

# ===========================================
# Admin
# ===========================================
# Password for admin routes authentication
ADMIN_PASSWORD=your_admin_password_here
